# ======================================
# EMAIL CONFIGURATION (для отправки уведомлений)
# ======================================

# Для SMTP сервера (например Яндекс.Почта, Gmail, Mailgun)
# 
# ВАРИАНТ 1: Яндекс.Почта (SMTP)
# Подробно: https://yandex.ru/support/mail/mail-clients.html
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@yandex.ru
SMTP_PASS=your-app-password  # Пароль приложения (не основной пароль)
SMTP_FROM=noreply@yandex.ru

# ВАРИАНТ 2: Gmail SMTP
# (требуется 2FA и пароль приложения)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@gmail.com

# ВАРИАНТ 3: Mailgun
# SMTP_HOST=smtp.mailgun.org
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=postmaster@your-domain.mailgun.org
# SMTP_PASS=your-mailgun-password
# SMTP_FROM=noreply@your-domain.mailgun.org

# ======================================
# Как настроить:
# ======================================
# 
# 1. Выбери почтовый сервис (Яндекс, Gmail, etc)
# 2. Получи SMTP креденшалы
# 3. Заполни переменные ниже
# 4. Сохрани в .env.local
# 5. Перезагрузи сервер (npm run dev)
#
# После этого письма будут отправляться автоматически при:
# - Создании заказа (email от зарегистрированного пользователя)
# - Изменении статуса заказа
# ======================================
