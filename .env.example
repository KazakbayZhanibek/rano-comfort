# Database (Supabase recommended)
DATABASE_URL="postgresql://postgres:password@localhost:5432/rano_komfort"

# NextAuth Configuration
NEXTAUTH_SECRET="your-secret-key-here-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# Admin Panel
ADMIN_SECRET="your-admin-password-here"

# Email Notifications (SMTP)
SMTP_HOST="smtp.yandex.ru"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@yandex.ru"
SMTP_PASS="your-app-password-here"
SMTP_FROM="noreply@your-domain.kz"

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_CHAT_ID="your-telegram-chat-id"

# Next.js
NODE_ENV="development"
